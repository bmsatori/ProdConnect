rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOwner == true;
    }

    function isOnRequestersTeam(teamCode) {
      return isSignedIn() && teamCode != null && normalizedTeamCode() != null
        && teamCode.lower() == normalizedTeamCode();
    }

    function canManageExistingUser(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && !resource.data.isOwner
        && isOnRequestersTeam(resource.data.teamCode)
        && (isOwner() || (isAdmin() && resource.data.isAdmin != true));
    }

    match /invites/{inviteId} {
      allow read, create, update, delete: if isAdmin();
    }

    function getUserTeamCode() {
      return isSignedIn() ?
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamCode : null;
    }

    function normalizedTeamCode() {
      return getUserTeamCode() != null ? getUserTeamCode().lower() : null;
    }

    function requestedTeamCode() {
      return request.resource.data.teamCode;
    }

    function hasRequestedTeamCode() {
      return requestedTeamCode() is string && requestedTeamCode().size() > 0;
    }

    function isCreatingOwnTeam(teamId) {
      return isSignedIn()
        && !exists(/databases/$(database)/documents/teams/$(teamId))
        && request.resource.data.code == teamId
        && request.resource.data.isActive == true
        && request.resource.data.createdBy is string;
    }

    function requestedTeamCodeIsValid() {
      return !hasRequestedTeamCode()
        || (
          requestedTeamCode().matches('^[A-Z0-9]{6}$')
          && exists(/databases/$(database)/documents/teams/$(requestedTeamCode()))
          && get(/databases/$(database)/documents/teams/$(requestedTeamCode())).data.isActive == true
        );
    }

    function belongsToUserTeam() {
      return isSignedIn() && resource.data.teamCode == getUserTeamCode()
        || (isSignedIn() && resource.data.teamCode != null && normalizedTeamCode() != null
            && resource.data.teamCode.lower() == normalizedTeamCode());
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId)
        || (isSignedIn() && resource.data.teamCode == getUserTeamCode())
        || (isSignedIn() && resource.data.teamCode != null && normalizedTeamCode() != null
            && resource.data.teamCode.lower() == normalizedTeamCode());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && requestedTeamCodeIsValid()
        && request.resource.data.isAdmin != true
        && request.resource.data.isOwner != true;
      allow update: if canManageExistingUser(userId) || (isSignedIn() && request.auth.uid == userId);
      allow delete: if canManageExistingUser(userId);
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isCreatingOwnTeam(teamId);
      allow update, delete: if isAdmin();
      
      match /locations/{locationId} {
        allow read, write: if isOnRequestersTeam(teamId);
      }
      
      match /rooms/{roomId} {
        allow read, write: if isOnRequestersTeam(teamId);
      }

      match /integrations/{integrationId} {
        allow read, write: if isSignedIn()
          && isOnRequestersTeam(teamId)
          && (isAdmin() || isOwner());
      }
    }

    match /lessons/{lessonId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /checklists/{checklistId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /ideas/{ideaId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /tickets/{ticketId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /channels/{channelId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /gear/{gearId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /patchsheet/{patchId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }

    match /runOfShows/{showId} {
      allow read, write: if belongsToUserTeam();
      allow create: if isSignedIn() && request.resource.data.teamCode == getUserTeamCode();
    }
  }
}
